# انسخ هذا الملف إلى .env لتشغيل التطبيق مع PostgreSQL
# copy .env.example .env  (في Windows)
# cp .env.example .env    (في Mac/Linux)

# عنوان خادم الـ API (الخادم الذي يشغّل server/)
# - Vercel (للجميع): https://tulkarm-map.vercel.app
# - للحاسوب/الويب: http://localhost:3000
# - لجهاز Android محاكي: http://10.0.2.2:3000
# - لجهاز حقيقي على نفس الشبكة: http://192.168.x.x:3000
EXPO_PUBLIC_API_URL=https://tulkarm-map.vercel.app

# استخدم true لتفعيل الاتصال بـ PostgreSQL عبر الخادم
EXPO_PUBLIC_USE_API=true

# مفتاح Google Maps API للويب (مطلوب لربط Google Maps على المتصفح)
# 1. أنشئ مفتاح من: https://console.cloud.google.com/apis/credentials
# 2. فعّل "Maps JavaScript API" في المشروع
# 3. ضع المفتاح أدناه (استبدل your_actual_key_here بالمفتاح الحقيقي)
# 4. أعد تشغيل السيرفر: npx expo start --web
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_actual_key_here

# إذا ظهر خطأ Google Maps "Oops" فعّل هذا لاستخدام Leaflet بدلاً منه (اختياري)
# EXPO_PUBLIC_FORCE_LEAFLET_MAP=true
