# انسخ هذا الملف إلى .env: copy .env.example .env

DATABASE_URL=postgresql://postgres:123456@localhost:5432/tulkarm-map

# منفذ الخادم
PORT=3000

# JWT (مطلوب للنسخة v2)
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# CORS
CORS_ORIGIN=*

# بيئة التشغيل
NODE_ENV=development
