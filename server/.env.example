# انسخ هذا الملف إلى .env: copy .env.example .env

# رابط اتصال قاعدة البيانات (مطلوب)
# للاتصال بـ Neon:
#   1. افتح Neon Console → اضغط Connect
#   2. اختر Node.js أو Connection string
#   3. انسخ الرابط وضعّه أدناه (استبدل القيمة كاملة)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# منفذ الخادم
PORT=3000

# JWT (مطلوب للنسخة v2)
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# Cloudinary (اختياري - لرفع الصور)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ORIGIN=*

# بيئة التشغيل
NODE_ENV=development
